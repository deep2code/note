## 六、蓝牙开发的高级技巧

### 6.1 重连机制：设备断开后自动重连

```javascript
// 监听连接状态变化
wx.onBLEConnectionStateChange((res) => {
  if (!res.connected) {
    console.log('设备断开，准备重连');
    // 延迟3秒后重连
    setTimeout(() => {
      wx.createBLEConnection({
        deviceId: res.deviceId,
        success: () => {
          console.log('重连成功');
        }
      });
    }, 3000);
  }
});
```

### 6.2 多设备管理：同时控制多个蓝牙设备

```javascript
// 维护设备映射
const deviceMap = new Map();

// 连接多个设备
async function connectMultipleDevices(deviceIds) {
  for (const deviceId of deviceIds) {
    await wx.createBLEConnection({ deviceId });
    deviceMap.set(deviceId, {
      connected: true,
      serviceId: null,
      characteristicId: null
    });
  }
}

// 向指定设备发送指令
function sendToDevice(deviceId, command) {
  const device = deviceMap.get(deviceId);
  if (device && device.connected) {
    wx.writeBLECharacteristicValue({
      deviceId,
      serviceId: device.serviceId,
      characteristicId: device.characteristicId,
      value: command.buffer
    });
  }
}
```

### 6.3 数据加密：提升通信安全性

```javascript
// 使用AES加密指令数据
async function encryptCommand(data, key) {
  const encoder = new TextEncoder();
  const keyData = encoder.encode(key);
  const iv = crypto.getRandomValues(new Uint8Array(16));
  
  const cryptoKey = await crypto.subtle.importKey(
    'raw', keyData, { name: 'AES-CBC' }, false, ['encrypt']
  );
  
  const encrypted = await crypto.subtle.encrypt(
    { name: 'AES-CBC', iv }, cryptoKey, data
  );
  
  return new Uint8Array(encrypted);
}
```

### 6.4 信号强度检测：判断设备距离

```javascript
// 获取RSSI信号强度
wx.getBLEDeviceRSSI({
  deviceId,
  success: (res) => {
    const rssi = res.RSSI;
    console.log('信号强度:', rssi, 'dBm');
    
    // 根据信号强度估算距离
    let distance;
    if (rssi > -50) {
      distance = '非常近（1米内）';
    } else if (rssi > -70) {
      distance = '较近（1-3米）';
    } else if (rssi > -85) {
      distance = '中等（3-10米）';
    } else {
      distance = '较远（10米外）';
    }
    console.log('预估距离:', distance);
  }
});
