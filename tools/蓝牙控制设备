## 四、独立App中的蓝牙开发：更强大的控制能力

### 4.1 为什么需要独立App？

- 更丰富的功能（数据分析、设备管理等）
- 后台保活能力更强
- 不受小程序平台限制
- 可以集成更多第三方SDK

### 4.2 iOS原生蓝牙开发：CoreBluetooth框架

#### 4.2.1 CoreBluetooth核心类

```mermaid
classDiagram
    class CBCentralManager {
        +scanForPeripherals()
        +connect()
        +delegate
    }
    class CBPeripheral {
        +discoverServices()
        +discoverCharacteristics()
        +writeValue()
        +setNotifyValue()
        +delegate
    }
    class CBService {
        +UUID
        +characteristics
    }
    class CBCharacteristic {
        +UUID
        +value
        +properties
    }
    CBCentralManager --> CBPeripheral
    CBPeripheral --> CBService
    CBService --> CBCharacteristic
```

#### 4.2.2 iOS实战代码

**步骤1：创建并初始化Central Manager**

```swift
import CoreBluetooth

class BluetoothManager: NSObject, CBCentralManagerDelegate, CBPeripheralDelegate {
    var centralManager: CBCentralManager!
    var connectedPeripheral: CBPeripheral?
    var targetCharacteristic: CBCharacteristic?
    
    override init() {
        super.init()
        // 初始化蓝牙管理器
        centralManager = CBCentralManager(delegate: self, queue: nil)
    }
    
    // 蓝牙状态变化回调
    func centralManagerDidUpdateState(_ central: CBCentralManager) {
        switch central.state {
        case .poweredOn:
            print("蓝牙已开启，开始扫描")
            centralManager.scanForPeripherals(withServices: nil, options: nil)
        case .poweredOff:
            print("蓝牙未开启")
        default:
            print("蓝牙状态: \(central.state)")
        }
    }
}
```

**步骤2：扫描并连接设备**

```swift
// 发现设备回调
func centralManager(_ central: CBCentralManager, 
                   didDiscover peripheral: CBPeripheral,
                   advertisementData: [String: Any],
                   rssi RSSI: NSNumber) {
    let deviceName = advertisementData[CBAdvertisementDataLocalNameKey] as? String
    
    // 过滤目标设备
    if deviceName?.contains("SmartLight") == true {
        print("找到目标设备: \(deviceName ?? "")")
        
        // 停止扫描
        centralManager.stopScan()
        
        // 连接设备
        connectedPeripheral = peripheral
        peripheral.delegate = self
        centralManager.connect(peripheral, options: nil)
    }
}

// 连接成功回调
func centralManager(_ central: CBCentralManager, 
                   didConnect peripheral: CBPeripheral) {
    print("设备连接成功")
    // 发现服务
    peripheral.discoverServices(nil)
}
```

**步骤3：发现服务和特征值**

```swift
// 发现服务回调
func peripheral(_ peripheral: CBPeripheral, 
               didDiscoverServices error: Error?) {
    guard let services = peripheral.services else { return }
    
    for service in services {
        print("发现服务: \(service.uuid)")
        // 发现该服务下的特征值
        peripheral.discoverCharacteristics(nil, for: service)
    }
}

// 发现特征值回调
func peripheral(_ peripheral: CBPeripheral, 
               didDiscoverCharacteristicsFor service: CBService, 
               error: Error?) {
    guard let characteristics = service.characteristics else { return }
    
    for characteristic in characteristics {
        print("发现特征值: \(characteristic.uuid)")
        
        // 寻找可写的特征值
        if characteristic.properties.contains(.write) {
            targetCharacteristic = characteristic
        }
        
        // 开启通知
        if characteristic.properties.contains(.notify) {
            peripheral.setNotifyValue(true, for: characteristic)
        }
    }
}
```

**步骤4：发送指令和接收数据**

```swift
// 发送控制指令
func sendCommand(_ command: Data) {
    guard let peripheral = connectedPeripheral,
          let characteristic = targetCharacteristic else {
        print("设备未连接或特征值未找到")
        return
    }
    
    peripheral.writeValue(command, 
                         for: characteristic, 
                         type: .withResponse)
}

// 接收设备上报数据
func peripheral(_ peripheral: CBPeripheral, 
               didUpdateValueFor characteristic: CBCharacteristic, 
               error: Error?) {
    guard let value = characteristic.value else { return }
    print("收到数据: \(value)")
    
    // 解析数据，更新UI
}

// 使用示例：开灯
let onCommand = Data([0x01])
sendCommand(onCommand)
```

### 4.3 Android原生蓝牙开发：BluetoothGatt API

#### 4.3.1 Android蓝牙架构

```mermaid
graph TD
    A[BluetoothAdapter] --> B[BluetoothDevice]
    B --> C[BluetoothGatt]
    C --> D[BluetoothGattService]
    D --> E[BluetoothGattCharacteristic]
    E --> F[写入数据 writeCharacteristic]
    E --> G[读取数据 readCharacteristic]
    E --> H[开启通知 setCharacteristicNotification]
```

#### 4.3.2 Android实战代码

**步骤1：初始化蓝牙并扫描**

```kotlin
class BluetoothController(private val context: Context) {
    private val bluetoothManager = context.getSystemService(Context.BLUETOOTH_SERVICE) 
        as BluetoothManager
    private var bluetoothGatt: BluetoothGatt? = null
    private var targetCharacteristic: BluetoothGattCharacteristic? = null
    
    private val gattCallback = object : BluetoothGattCallback() {
        override fun onConnectionStateChange(gatt: BluetoothGatt, 
                                           status: Int, 
                                           newState: Int) {
            if (newState == BluetoothProfile.STATE_CONNECTED) {
                Log.d("BLE", "设备连接成功")
                // 发现服务
                gatt.discoverServices()
            } else if (newState == BluetoothProfile.STATE_DISCONNECTED) {
                Log.d("BLE", "设备断开连接")
            }
        }
        
        override fun onServicesDiscovered(gatt: BluetoothGatt, status: Int) {
            if (status == BluetoothGatt.GATT_SUCCESS) {
                // 遍历服务和特征值
                gatt.services.forEach { service ->
                    Log.d("BLE", "服务: ${service.uuid}")
                    
                    service.characteristics.forEach { characteristic ->
                        Log.d("BLE", "特征值: ${characteristic.uuid}")
                        
                        // 保存可写的特征值
                        if (characteristic.properties and 
                            BluetoothGattCharacteristic.PROPERTY_WRITE != 0) {
                            targetCharacteristic = characteristic
                        }
                        
                        // 开启通知
                        if (characteristic.properties and 
                            BluetoothGattCharacteristic.PROPERTY_NOTIFY != 0) {
                            gatt.setCharacteristicNotification(characteristic, true)
                        }
                    }
                }
            }
        }
        
        override fun onCharacteristicRead(gatt: BluetoothGatt, 
                                        characteristic: BluetoothGattCharacteristic, 
                                        status: Int) {
            // 读取数据回调
        }
        
        override fun onCharacteristicChanged(gatt: BluetoothGatt, 
                                           characteristic: BluetoothGattCharacteristic) {
            // 数据变化通知
            val value = characteristic.value
            Log.d("BLE", "收到数据: ${value.contentToString()}")
        }
    }
}
```

**步骤2：扫描和连接设备**

```kotlin
// 使用BluetoothLeScanner扫描设备
fun startScan() {
    val bluetoothAdapter = bluetoothManager.adapter
    if (!bluetoothAdapter.isEnabled) {
        Log.e("BLE", "蓝牙未开启")
        return
    }
    
    val scanner = bluetoothAdapter.bluetoothLeScanner
    val scanCallback = object : ScanCallback() {
        override fun onScanResult(callbackType: Int, result: ScanResult) {
            val device = result.device
            if (device.name?.contains("SmartLight") == true) {
                Log.d("BLE", "找到设备: ${device.name}")
                // 停止扫描
                scanner.stopScan(this)
                // 连接设备
                connectDevice(device)
            }
        }
    }
    
    scanner.startScan(scanCallback)
}

fun connectDevice(device: BluetoothDevice) {
    bluetoothGatt = device.connectGatt(context, false, gattCallback)
}
```

**步骤3：写入和读取数据**

```kotlin
// 发送控制指令
fun writeCommand(command: ByteArray) {
    targetCharacteristic?.let { characteristic ->
        characteristic.value = command
        characteristic.writeType = BluetoothGattCharacteristic.WRITE_TYPE_DEFAULT
        bluetoothGatt?.writeCharacteristic(characteristic)
    }
}

// 读取数据
fun readData() {
    targetCharacteristic?.let { characteristic ->
        bluetoothGatt?.readCharacteristic(characteristic)
    }
}

// 使用示例
val controller = BluetoothController(context)
controller.startScan()

// 连接成功后发送指令
val onCommand = byteArrayOf(0x01.toByte())
controller.writeCommand(onCommand)
```

### 4.4 跨平台方案：Flutter蓝牙开发

如果你不想写两套代码，Flutter的`flutter_blue_plus`插件是个不错的选择：

```dart
import 'package:flutter_blue_plus/flutter_blue_plus.dart';

// 扫描设备
FlutterBluePlus.scanResults.listen((results) {
  for (ScanResult result in results) {
    if (result.device.name.contains('SmartLight')) {
      // 连接设备
      connectToDevice(result.device);
    }
  }
});

// 连接设备
Future<void> connectToDevice(BluetoothDevice device) async {
  await device.connect();
  
  // 发现服务
  List<BluetoothService> services = await device.discoverServices();
  
  // 遍历特征值
  for (var service in services) {
    for (var characteristic in service.characteristics) {
      // 写入数据
      if (characteristic.properties.write) {
        await characteristic.write([0x01]);
      }
      
      // 监听数据
      if (characteristic.properties.notify) {
        characteristic.setNotifyValue(true);
        characteristic.lastValueStream.listen((value) {
          print('收到数据: $value');
        });
      }
    }
  }
}
```

