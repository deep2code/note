### 5.2 切片插入与删除

#### slices.Insert - 在指定位置插入元素

```go
package main

import (
    "fmt"
    "slices"
)

func main() {
    numbers := []int{1, 2, 3, 4, 5}
    
    // 在索引2处插入元素
    result := slices.Insert(numbers, 2, 99)
    fmt.Println("插入99后:", result) // [1 2 99 3 4 5]
    
    // 插入多个元素
    result2 := slices.Insert(numbers, 2, 88, 99, 100)
    fmt.Println("插入多个元素后:", result2) // [1 2 88 99 100 3 4 5]
    
    // 在开头插入
    result3 := slices.Insert(numbers, 0, 0)
    fmt.Println("开头插入后:", result3) // [0 1 2 3 4 5]
    
