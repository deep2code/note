## 七、实战篇：综合案例

### 7.1 案例1：日志过滤器

```go
package main

import (
    "fmt"
    "slices"
    "strings"
)

type Log struct {
    Level   string
    Message string
}

func main() {
    logs := []Log{
        {"INFO", "Application started"},
        {"DEBUG", "Loading config"},
        {"WARN", "High memory usage"},
        {"ERROR", "Connection failed"},
        {"INFO", "Retrying connection"},
        {"DEBUG", "Cache cleared"},
    }
    
    // 过滤出WARN及以上级别的日志
    warnLevels := []string{"WARN", "ERROR", "FATAL"}
    
    var importantLogs []Log
    for _, log := range logs {
        if slices.Contains(warnLevels, log.Level) {
            importantLogs = append(importantLogs, log)
        }
    }
    
    fmt.Println("重要日志:")
    for _, log := range importantLogs {
        fmt.Printf("[%s] %s\n", log.Level, log.Message)
    }
}
```

### 7.2 案例2：去重排序

```go
package main

import (
    "fmt"
    "slices"
)

func main() {
    // 有一堆标签，需要去重并排序
    tags := []string{
        "golang", "tutorial", "go", "slices",
        "golang", "beginner", "tutorial", "go",
    }
    
    // 步骤1：排序
    slices.Sort(tags)
    fmt.Println("排序后:", tags)
    
    // 步骤2：去重
    unique := slices.Compact(tags)
    fmt.Println("去重后:", unique)
}
```

### 7.3 案例3：批量数据处理

```go
package main

import (
    "cmp"
    "fmt"
    "slices"
)

type User struct {
    ID   int
    Name string
    Age  int
}

func main() {
    // 模拟从数据库获取的数据
    users := []User{
        {3, "Alice", 25},
        {1, "Bob", 30},
        {4, "Charlie", 20},
        {2, "David", 30},
        {5, "Eve", 25},
    }
    
    // 需求1：按ID排序
    slices.SortFunc(users, func(a, b User) int {
        return cmp.Compare(a.ID, b.ID)
    })
    fmt.Println("按ID排序:")
    printUsers(users)
    
    // 需求2：查找ID为3的用户
    idx := slices.BinarySearchFunc(users, User{ID: 3}, func(a, b User) int {
        return cmp.Compare(a.ID, b.ID)
    })
    if idx >= 0 {
        fmt.Printf("找到ID为3的用户: %s\n", users[idx].Name)
    }
    
    // 需求3：删除ID为2的用户
    delIdx := slices.IndexFunc(users, func(u User) bool {
        return u.ID == 2
    })
    if delIdx >= 0 {
        users = slices.Delete(users, delIdx, delIdx+1)
        fmt.Println("删除ID为2的用户后:")
        printUsers(users)
    }
}

func printUsers(users []User) {
    for _, u := range users {
        fmt.Printf("  ID: %d, Name: %s, Age: %d\n", u.ID, u.Name, u.Age)
    }
}
```

