    Cloned --> Len2[长度: 5]
    Cloned --> Cap2[容量: 5]
    
    Ptr1 --> Array1[独立数组1: 1,2,3,4,5]
    Ptr2 --> Array2[独立数组2: 1,2,3,4,5]
    
