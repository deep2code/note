```

#### slices.Copy - 复制元素

```go
package main

import (
    "fmt"
    "slices"
)

func main() {
    src := []int{1, 2, 3, 4, 5}
    dst := make([]int, 3)
    
    // 从src复制到dst，返回复制的元素个数
    n := slices.Copy(dst, src)
    
    fmt.Printf("复制了 %d 个元素\n", n) // 输出: 3
    fmt.Println("dst:", dst)            // 输出: [1 2 3]
    
    // 目标切片更大时
    dst2 := make([]int, 10)
    n2 := slices.Copy(dst2, src)
    fmt.Printf("复制了 %d 个元素\n", n2) // 输出: 5
    fmt.Println("dst2:", dst2)          // 输出: [1 2 3 4 5 0 0 0 0 0]
}
```

### 3.2 切片替换与插入

#### slices.Replace - 替换切片中的元素

```go
package main

import (
    "fmt"
    "slices"
)

func main() {
    numbers := []int{1, 2, 3, 4, 5, 6, 7}
    
    // 从索引2开始，替换2个元素为99, 100
    result := slices.Replace(numbers, 2, 4, 99, 100)
    fmt.Println("替换后:", result) // [1 2 99 100 5 6 7]
    
    // 替换时可以改变长度
    numbers2 := []int{1, 2, 3, 4, 5}
    
    // 删除元素：替换范围为[1:4]，但不提供新元素
    result2 := slices.Replace(numbers2, 1, 4)
    fmt.Println("删除后:", result2) // [1 5]
    
    // 插入元素：替换范围为[2:2]，提供新元素
    numbers3 := []int{1, 2, 3, 4, 5}
    result3 := slices.Replace(numbers3, 2, 2, 99, 100)
    fmt.Println("插入后:", result3) // [1 2 99 100 3 4 5]
}
```

### 3.3 切片去重

#### slices.Compact - 删除连续重复元素

注意：`Compact`只删除**连续**的重复元素，如果要完全去重，需要先排序！

```go
package main

import (
    "fmt"
    "slices"
)

func main() {
    // 连续重复
    numbers := []int{1, 1, 2, 2, 2, 3, 3, 1, 1}
    result := slices.Compact(numbers)
    fmt.Println("压缩后:", result) // [1 2 3 1]
    
    // 完全去重：先排序，再Compact
    numbers2 := []int{3, 1, 2, 3, 1, 2, 1}
    slices.Sort(numbers2)
    result2 := slices.Compact(numbers2)
    fmt.Println("排序+压缩后:", result2) // [1 2 3]
}
```

#### slices.CompactFunc - 自定义去重逻辑

```go
package main

import (
    "fmt"
    "slices"
    "strings"
)

func main() {
    // 字符串切片，忽略大小写去重
    words := []string{"Go", "GO", "go", "Python", "python"}
    
    result := slices.CompactFunc(words, func(a, b string) bool {
        return strings.EqualFold(a, b)
    })
    
    fmt.Println("自定义去重:", result) // [Go Python]
    // 注意：需要先按自定义比较函数排序
}
```

